-- AutoFarm Boss Script (v6 - Clean)
-- LocalScript in StarterPlayerScripts

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local VirtualInputManager = game:GetService("VirtualInputManager")
local player = Players.LocalPlayer

local QUEST_BOSSES = {
	{ boss = "[Lv.15000] Thorvak", npcId = "240010", questId = "Quest_230010" },
	{ boss = "[Lv.15000] Hraegon", npcId = "240011", questId = "Quest_230011" },
	{ boss = "[Lv.15000] Niflor",  npcId = "240008", questId = "Quest_230008" },
	{ boss = "[Lv.15000] Surtrik", npcId = "240009", questId = "Quest_230009" },
}

local BOSS_PRIORITY = {
	"[Lv.15000] Thorvak",
	"[Lv.15000] Hraegon",
	"[Lv.15000] Niflor",
	"[Lv.15000] Surtrik",
	"[Lv.3000] Black Swordsman",
	"[Lv.???] Gelaros",
	"[Lv.8500] Nivaron",
	"[Lv.6000] Velik",
	"[Lv.3500] Ragaros",
	"[Lv.2500] Magador",
	"[Lv.750] Moraros",
}

local OFFSET = 2
local AFK_CF = CFrame.new(-2747.516602, 285.039551, -2140.749023) * CFrame.Angles(-3.141593, 1.218626, -3.141593)

local enabled = false
local selectedBosses = {}
for _, name in ipairs(BOSS_PRIORITY) do selectedBosses[name] = true end

local currentTarget = nil
local farmConnection = nil
local questInProgress = false

local function getHRP()
	local char = player.Character
	if not char then return nil end
	return char:FindFirstChild("HumanoidRootPart")
end

local function getQuestData(bossName)
	for _, data in ipairs(QUEST_BOSSES) do
		if data.boss == bossName then return data end
	end
	return nil
end

local function isQuestReady(questId)
	local ok, result = pcall(function()
		local taskPanel = player.PlayerGui.Main.HomePage.TaskPanel.Content.Task
		local quest = taskPanel:FindFirstChild(questId)
		if not quest then return false end
		return quest.Outline.Task.Icon.Number.Text == "2"
	end)
	return ok and result
end

local function isBossAlive(name)
	local model = workspace.EnemyService:FindFirstChild(name)
	if not model then return false end
	local hum = model:FindFirstChild("Humanoid")
	if not hum then return false end
	return hum.Health > 100
end

local function getBestAvailableBoss()
	for _, name in ipairs(BOSS_PRIORITY) do
		if selectedBosses[name] and isBossAlive(name) then
			return name
		end
	end
	return nil
end

local function snapToBoss(name)
	local hrp = getHRP()
	if not hrp then return end
	local model = workspace.EnemyService:FindFirstChild(name)
	if not model then return end
	local hum = model:FindFirstChild("Humanoid")
	if not hum or hum.Health <= 100 then return end
	local bossPos = model:GetPivot().Position
	local targetPos = bossPos + Vector3.new(0, -OFFSET, 0)
	local targetCF = CFrame.new(targetPos, bossPos)
	hrp.CFrame = targetCF
	task.defer(function()
		local h = getHRP()
		if h then h.CFrame = targetCF end
	end)
end

local function acceptQuest(bossName, npcId, questId)
	local npc = workspace.World.NPC.BossTask:FindFirstChild(npcId)
	if not npc then
		return false
	end

	local done = false

	local conn = RunService.Heartbeat:Connect(function()
		if done then return end

		if isQuestReady(questId) then
			done = true
			return
		end

		local hrp = getHRP()
		if hrp and npc.Parent then
			local npcPos = npc:GetPivot().Position

			hrp.CFrame = CFrame.new(
				npcPos + Vector3.new(0, OFFSET, 0),
				npcPos
			)
		end
	end)

while not done and npc.Parent do

    if not isBossAlive(bossName) then
        print("Boss died while getting quest")
        done = true
        break
    end

    local talk = npc:FindFirstChild("Talk")

    if talk then
        local prompt = talk:FindFirstChildOfClass("ProximityPrompt")

        if prompt and prompt.Enabled then
            pcall(function()
                fireproximityprompt(prompt)
            end)
        end
    end

    task.wait(0.3)
end

conn:Disconnect()

if not isBossAlive(bossName) then
    return false
end

return isQuestReady(questId)
end

local function handleQuestBoss(bossName)
    if questInProgress then
        return
    end

    local data = getQuestData(bossName)
    if not data then
        return
    end

    if isQuestReady(data.questId) then
        return
    end

    questInProgress = true

    task.spawn(function()

        local success = acceptQuest(
            bossName,
            data.npcId,
            data.questId
        )

        if success then
    print("Ready to kill:", bossName)
else
    currentTarget = getBestAvailableBoss()
    updateStatus()
end

questInProgress = false
    end)
end

-- ==================== GUI ====================
local gui = Instance.new("ScreenGui")
gui.Name = "AutoFarmGUI"
gui.ResetOnSpawn = false
gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
gui.Parent = player:WaitForChild("PlayerGui")

local WIN_W = 270
local BOSS_COUNT = #BOSS_PRIORITY
local CHECKBOX_START_Y = 52
local CHECKBOX_STEP = 24
local STATUS_Y = CHECKBOX_START_Y + (BOSS_COUNT * CHECKBOX_STEP) + 10
local BTN_Y = STATUS_Y + 46
local WIN_H = BTN_Y + 38

local main = Instance.new("Frame")
main.Size = UDim2.new(0, WIN_W, 0, WIN_H)
main.Position = UDim2.new(0.5, -WIN_W/2, 0, 60)
main.BackgroundColor3 = Color3.fromRGB(18, 18, 32)
main.BorderSizePixel = 0
main.Active = true
main.Draggable = true
main.Parent = gui
Instance.new("UICorner", main).CornerRadius = UDim.new(0, 8)
local ws = Instance.new("UIStroke", main)
ws.Color = Color3.fromRGB(127, 119, 221)
ws.Thickness = 1

local function makeText(parent, text, x, y, w, h, size, color, bold)
	local l = Instance.new("TextLabel")
	l.Position = UDim2.new(0, x, 0, y)
	l.Size = UDim2.new(0, w, 0, h)
	l.BackgroundTransparency = 1
	l.Text = text
	l.TextSize = size or 12
	l.TextColor3 = color or Color3.fromRGB(220, 220, 220)
	l.Font = bold and Enum.Font.GothamBold or Enum.Font.Gotham
	l.TextXAlignment = Enum.TextXAlignment.Left
	l.ZIndex = 3
	l.Parent = parent
	return l
end

local function makeBtn(parent, text, x, y, w, h)
	local b = Instance.new("TextButton")
	b.Position = UDim2.new(0, x, 0, y)
	b.Size = UDim2.new(0, w, 0, h)
	b.BackgroundColor3 = Color3.fromRGB(40, 40, 70)
	b.Text = text
	b.TextColor3 = Color3.fromRGB(200, 195, 255)
	b.TextSize = 12
	b.Font = Enum.Font.GothamBold
	b.BorderSizePixel = 0
	b.ZIndex = 4
	b.Parent = parent
	Instance.new("UICorner", b).CornerRadius = UDim.new(0, 6)
	local s = Instance.new("UIStroke", b)
	s.Color = Color3.fromRGB(127, 119, 221)
	s.Thickness = 0.5
	return b
end

local titleBar = Instance.new("Frame")
titleBar.Size = UDim2.new(1, 0, 0, 30)
titleBar.Position = UDim2.new(0, 0, 0, 0)
titleBar.BackgroundColor3 = Color3.fromRGB(22, 20, 45)
titleBar.BorderSizePixel = 0
titleBar.ZIndex = 2
titleBar.Parent = main
Instance.new("UICorner", titleBar).CornerRadius = UDim.new(0, 8)
makeText(titleBar, "⚔  Auto Farm", 12, 0, 200, 30, 13, Color3.fromRGB(175, 169, 236), true)
makeText(main, "เลือกบอส:", 12, 36, 200, 16, 11, Color3.fromRGB(175, 169, 236), false)

local checkStates = {}
for i, name in ipairs(BOSS_PRIORITY) do
	local y = CHECKBOX_START_Y + (i - 1) * CHECKBOX_STEP

	if i == 5 then
		local sep = Instance.new("Frame")
		sep.Position = UDim2.new(0, 12, 0, y - 4)
		sep.Size = UDim2.new(0, WIN_W - 24, 0, 1)
		sep.BackgroundColor3 = Color3.fromRGB(80, 75, 150)
		sep.BorderSizePixel = 0
		sep.ZIndex = 3
		sep.Parent = main
	end

	local cb = Instance.new("TextButton")
	cb.Position = UDim2.new(0, 12, 0, y)
	cb.Size = UDim2.new(0, 16, 0, 16)
	cb.BackgroundColor3 = Color3.fromRGB(83, 74, 183)
	cb.Text = "✓"
	cb.TextColor3 = Color3.fromRGB(238, 237, 254)
	cb.TextSize = 10
	cb.Font = Enum.Font.GothamBold
	cb.BorderSizePixel = 0
	cb.ZIndex = 4
	cb.Parent = main
	Instance.new("UICorner", cb).CornerRadius = UDim.new(0, 3)

	local isQuest = getQuestData(name) ~= nil
	local lbl = makeText(main, isQuest and ("[Q] "..name) or name, 34, y, WIN_W-46, 16, 11,
		isQuest and Color3.fromRGB(255, 210, 100) or Color3.fromRGB(210, 210, 210), false)
	lbl.TextTruncate = Enum.TextTruncate.AtEnd
	checkStates[name] = true

	cb.MouseButton1Click:Connect(function()
		checkStates[name] = not checkStates[name]
		selectedBosses[name] = checkStates[name]
		if checkStates[name] then
			cb.BackgroundColor3 = Color3.fromRGB(83, 74, 183)
			cb.Text = "✓"
			lbl.TextColor3 = isQuest and Color3.fromRGB(255, 210, 100) or Color3.fromRGB(210, 210, 210)
		else
			cb.BackgroundColor3 = Color3.fromRGB(45, 45, 65)
			cb.Text = ""
			lbl.TextColor3 = Color3.fromRGB(90, 90, 110)
		end
	end)
end

local statusBox = Instance.new("Frame")
statusBox.Position = UDim2.new(0, 12, 0, STATUS_Y)
statusBox.Size = UDim2.new(0, WIN_W - 24, 0, 38)
statusBox.BackgroundColor3 = Color3.fromRGB(22, 33, 62)
statusBox.BorderSizePixel = 0
statusBox.ZIndex = 2
statusBox.Parent = main
Instance.new("UICorner", statusBox).CornerRadius = UDim.new(0, 6)

local s1 = makeText(statusBox, "● รอเริ่ม...", 8, 4, WIN_W-40, 14, 11, Color3.fromRGB(159, 225, 203), false)
local s2 = makeText(statusBox, "", 8, 20, WIN_W-40, 14, 11, Color3.fromRGB(120, 120, 140), false)

local function updateStatus()
	if not enabled then s1.Text = "■ หยุดทำงาน" s2.Text = "" return end
	if currentTarget then
		local qd = getQuestData(currentTarget)
		local prefix = qd and (isQuestReady(qd.questId) and "⚔ " or "📋 ") or "● "
		s1.Text = prefix .. "ติดตาม: " .. currentTarget
		local found, nextBoss = false, ""
		for _, name in ipairs(BOSS_PRIORITY) do
			if name == currentTarget then found = true
			elseif found and selectedBosses[name] then nextBoss = name break end
		end
		s2.Text = nextBoss ~= "" and ("ถัดไป: "..nextBoss) or "ไม่มีตัวถัดไป"
	else
		s1.Text = "○ รอบอสเกิด..."
		s2.Text = "กำลังรอที่จุด AFK"
	end
end

local BW = WIN_W - 24
local toggleBtn = makeBtn(main, "▶  เริ่ม", 12, BTN_Y, BW, 28)
toggleBtn.BackgroundColor3 = Color3.fromRGB(30, 80, 40)
local ts = Instance.new("UIStroke", toggleBtn)
ts.Color = Color3.fromRGB(60, 180, 80)
ts.Thickness = 0.5

toggleBtn.MouseButton1Click:Connect(function()
	enabled = not enabled
	if enabled then
		toggleBtn.Text = "■  หยุด"
		toggleBtn.BackgroundColor3 = Color3.fromRGB(80, 25, 25)
		ts.Color = Color3.fromRGB(180, 60, 60)
		currentTarget = getBestAvailableBoss()
		updateStatus()
		if farmConnection then farmConnection:Disconnect() end
		farmConnection = RunService.Heartbeat:Connect(function()
			if not enabled then return end

			if currentTarget and isBossAlive(currentTarget) then
				local qData = getQuestData(currentTarget)
				if qData then
					if isQuestReady(qData.questId) then
						snapToBoss(currentTarget)
					else
						handleQuestBoss(currentTarget)
					end
				else
					snapToBoss(currentTarget)
				end
				return
			end

			local best = getBestAvailableBoss()
			if best ~= currentTarget then
				currentTarget = best
				questInProgress = false
				updateStatus()
			end

			if not currentTarget then
				local hrp = getHRP()
				if hrp then hrp.CFrame = AFK_CF end
			end
		end)
	else
		toggleBtn.Text = "▶  เริ่ม"
		toggleBtn.BackgroundColor3 = Color3.fromRGB(30, 80, 40)
		ts.Color = Color3.fromRGB(60, 180, 80)
		currentTarget = nil
		questInProgress = false
		if farmConnection then farmConnection:Disconnect() end
		updateStatus()
	end
end)

updateStatus()
